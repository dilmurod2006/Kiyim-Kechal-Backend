# Production environment — copy to `.env.prod` ON THE SERVER and fill in real
# values. NEVER commit the real .env.prod to git (it is gitignored).
#
#   cp .env.prod.example .env.prod && nano .env.prod

# --- PostgreSQL container credentials ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=fastapi_ecom

# --- Database connection strings (host must be the service name "db") ---
# Keep the user/password/db name in sync with the three values above.
DATABASE_URL=postgresql+asyncpg://postgres:change-me-to-a-strong-password@db:5432/fastapi_ecom
DATABASE_SYNC_URL=postgresql+psycopg2://postgres:change-me-to-a-strong-password@db:5432/fastapi_ecom

# --- App security (generate a new secret: `openssl rand -base64 32`) ---
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256

# --- Celery / Redis (host must be the service name "redis") ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
